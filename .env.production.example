# ════════════════════════════════════════════
#  COMPRAFIT - Variables de Entorno (Producción)
#  Copiar a .env y completar los valores
# ════════════════════════════════════════════

# ── Backend ──
NODE_ENV=production
PORT=5000

# ── Base de datos ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=comprafit
DB_USER=comprafit
DB_PASS=TU_PASSWORD_SEGURO

# ── Auth0 ──
AUTH0_DOMAIN=tu-tenant.auth0.com
AUTH0_AUDIENCE=https://api.comprafit.com
AUTH0_CLIENT_ID=

# ── Frontend URL (para CORS y emails) ──
FRONTEND_URL=https://tudominio.com

# ── Email (Resend) ──
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@tudominio.com

# ── TiendaNube (opcional) ──
TIENDANUBE_CLIENT_ID=
TIENDANUBE_CLIENT_SECRET=

# ── Frontend (se bakean al hacer build) ──
VITE_API_URL=https://api.tudominio.com/api
VITE_AUTH0_DOMAIN=tu-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://api.comprafit.com
